# Environment Configuration Template
# Copy this file to .env and fill in your values
# This file is used for server configuration

# ========================
# Database Configuration
# ========================

# SQLite (Development)
DATABASE_URL=sqlite:///./chat_app.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost/chat_app_db

# ========================
# Image Bot Credentials
# ========================
# Optional - needed only if you want image search/streaming features

# Danbooru API (Get from https://danbooru.donmai.us/)
DANBOORU_USER=your_danbooru_username
DANBOORU_API_KEY=your_danbooru_api_key

# Rule34 API (Get from https://rule34.xxx/)
RULE34_USER_ID=your_rule34_user_id
RULE34_API_KEY=your_rule34_api_key

# ========================
# Server Configuration
# ========================

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Secret key for security
SECRET_KEY=your_secret_key_here_change_in_production

# Enable debug mode (False in production!)
DEBUG=False

# ========================
# Security Configuration
# ========================

# SSL/HTTPS (Optional - for production)
# Path to SSL certificate and key files
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

# CORS settings
CORS_ORIGINS=["*"]

# ========================
# Logging Configuration
# ========================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
# LOG_FILE=/var/log/encrypted-chat/app.log

# ========================
# Session Configuration
# ========================

# Session timeout in hours
SESSION_TIMEOUT=24

# Maximum active sessions per user
MAX_SESSIONS_PER_USER=3

# ========================
# Rate Limiting
# ========================

# Enable rate limiting
ENABLE_RATE_LIMIT=True

# Requests per minute per IP
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ========================
# File Upload Configuration
# ========================

# Max file size in MB
MAX_FILE_SIZE_MB=50

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ========================
# Backup Configuration
# ========================

# Enable automatic backups
ENABLE_BACKUPS=True

# Backup interval in hours
BACKUP_INTERVAL_HOURS=24

# Backup directory
BACKUP_DIR=/home/your_user/backups

# Keep backups for (days)
BACKUP_RETENTION_DAYS=30

# ========================
# Monitoring & Alerts
# ========================

# Enable monitoring
ENABLE_MONITORING=True

# Server admin email (for alerts)
ADMIN_EMAIL=admin@example.com

# Monitoring interval (minutes)
MONITORING_INTERVAL_MINUTES=5

# ========================
# Email Configuration (Optional)
# ========================
# For sending email notifications

# SMTP Server
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email settings
FROM_EMAIL=noreply@example.com
FROM_NAME=Encrypted Chat

# ========================
# Cloudflare Tunnel (Optional)
# ========================
# For remote access without port forwarding

CLOUDFLARE_TUNNEL_NAME=encrypted-chat
CLOUDFLARE_ACCOUNT_TAG=your_account_id
CLOUDFLARE_TUNNEL_SECRET=your_tunnel_secret

# ========================
# Tailscale Configuration (Optional)
# ========================

# Tailscale API key
TAILSCALE_API_KEY=tskey_your_api_key

# ========================
# Development Settings
# ========================

# Disable SSL verification (Development ONLY!)
SSL_VERIFY=True

# Allow profiling
ENABLE_PROFILING=False

# Auto-reload on code changes
AUTO_RELOAD=False
